#!/usr/bin/env bash
# Control-plane dispatch — run as VIKTOR (the trusted operator), never as an agent.
#
#   dispatch <repo> [orchestrate options...]
#   dispatch <repo> --drain --force
#   dispatch <repo> --task TASK-15
#
# Resolves <repo> from the operator registry (~/.config/agent-runner, override with
# $AGENT_RUNNER_CONFIG), drops to that repo's Linux user, and hands off to
# `agent-runner orchestrate` — which fetches, prepares the work branch, and runs
# the loop itself. You never touch branches by hand.
#
# Passwordless once the sudoers rule is in place (see control/README.md); until
# then sudo prompts for viktor's password once per dispatch.
set -euo pipefail

CONFIG_DIR="${AGENT_RUNNER_CONFIG:-$HOME/.config/agent-runner}"

die() {
	echo "dispatch: $*" >&2
	exit 1
}

[ $# -ge 1 ] || die "usage: dispatch <repo> [orchestrate options...]"
repo="$1"
shift

repo_conf="$CONFIG_DIR/repos/$repo.conf"
[ -f "$repo_conf" ] || die "no registry entry at $repo_conf"

# Fleet defaults first, then the per-repo file overrides them.
defaults="$CONFIG_DIR/defaults.conf"
# shellcheck disable=SC1090
[ -f "$defaults" ] && source "$defaults"
# shellcheck disable=SC1090
source "$repo_conf"

: "${REPO_PATH:?$repo_conf must set REPO_PATH}"
: "${REPO_USER:?$repo_conf must set REPO_USER}"
PROXY="${PROXY:-}"

# The runner is THIS dispatch's sibling — its own standalone clone, not a copy
# inside the product repo. Update it with `git pull` in the runner clone; the
# product workspace's git is `orchestrate`'s job, so there is no pre-sync here.
runner="$(cd "$(dirname "$0")" && pwd)/agent-runner"

# Build the remote command with printf %q so every interpolated value is
# shell-safe — no string-quoting guesswork. dispatch supplies only the machine
# binding (workspace, proxy); assistant/model/effort come from the repo's
# .agent/config.json, and role defaults to dev (pass `--loop qa` to override).
# Headless executor: no GUI session. Pin D-Bus to a dead address and disable the
# AT-SPI bridge so chromium / libsecret inside a drain don't autolaunch a session
# bus + gnome-keyring daemon that nothing ever reaps (a slow, unbounded leak of
# idle processes). Set here in the runner so it travels to any executor — the
# agent's .bashrc can stop sourcing partway, so an rc-file export is unreliable.
remote='export DBUS_SESSION_BUS_ADDRESS=disabled: NO_AT_BRIDGE=1; '
# Let corepack reach the npm registry through the egress proxy so it can download
# and run each repo's pinned pnpm (the `packageManager` field) on demand. corepack
# ignores *_PROXY unless NODE_USE_ENV_PROXY=1; we set both casings since some setups
# only honor the lowercase ones, and exclude loopback so the proxy isn't proxied.
# Without this, an uncached pin fails on the egress drop and the loop can't run pnpm.
if [ -n "$PROXY" ]; then
	remote+=$(printf 'export NODE_USE_ENV_PROXY=1 HTTPS_PROXY=%q https_proxy=%q NO_PROXY=127.0.0.1,localhost no_proxy=127.0.0.1,localhost; ' \
		"$PROXY" "$PROXY")
fi
remote+=$(printf 'cd %q && %q orchestrate --workspace %q' \
	"$REPO_PATH" "$runner" "$REPO_PATH")
[ -n "$PROXY" ] && remote+=$(printf ' --proxy %q' "$PROXY")
for arg in "$@"; do remote+=$(printf ' %q' "$arg"); done

# One run per repo: a non-blocking flock so a second dispatch (e.g. the watcher
# polling while a run is active) fails fast with exit 75 instead of overlapping.
lockdir="$CONFIG_DIR/locks"
mkdir -p "$lockdir"
lock="$lockdir/$repo.lock"

echo "dispatch: $repo -> user=$REPO_USER" >&2
# `bash -lic` (login + interactive) so the agent's real toolchain loads: node/pnpm
# (fnm) and the agent CLIs (pnpm global bin) live in .bashrc, which only runs for
# interactive shells — a plain `bash -c` has none of them. This keeps the runner
# env-agnostic (the machine's dotfiles own the toolchain). The harmless "no job
# control in this shell" notice on stderr is expected (no controlling tty).
# `exec` so this script's file is not held open while the reset rewrites the tree.
exec flock -n -E 75 "$lock" sudo -iu "$REPO_USER" bash -lic "$remote"
