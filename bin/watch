#!/usr/bin/env bash
# Watcher — run as VIKTOR (typically via the systemd --user unit). Polls the
# operator registry and drains each repo's board through `dispatch`, so you just
# push tickets and walk away; no SSH, no manual dispatch.
#
# Stateless by design: the board is the queue, dispatch's flock is the per-repo
# mutex, and orchestrate early-exits when nothing is ready — so a poll over an
# idle/active repo is cheap (a busy repo's dispatch returns 75 and is skipped).
#
# One-off runs: `enqueue <repo> --loop steward` drops a job file under
# `$CONFIG_DIR/queue/<repo>/`; each tick that repo runs its oldest queued job
# (ahead of the drain) and removes it, so a scheduled pass is picked up at the next
# free slot without pausing or timing anything. Not a cron — it fires once, when free.
#
# Per-run status: each real run records `$CONFIG_DIR/status/<repo>` (time, what ran,
# ok/failed, the outcome line) so the last outcome is visible without opening a
# transcript — and the TUI can read it without sudo.
#
# Pause: `touch $CONFIG_DIR/PAUSED` (all repos) or `$CONFIG_DIR/repos/<name>.paused`
# (one repo). Stop entirely: `systemctl --user stop agent-watch`.
set -uo pipefail

CONFIG_DIR="${AGENT_RUNNER_CONFIG:-$HOME/.config/agent-runner}"
INTERVAL="${WATCH_INTERVAL:-120}"
DISPATCH="$(cd "$(dirname "$0")" && pwd)/dispatch"

log() { printf '[watch %s] %s\n' "$(date -Is)" "$*"; }

STATUS_DIR="$CONFIG_DIR/status"

# Record a run's outcome so it's visible without opening a transcript (and so the TUI
# can read it without sudo). One small key=value file per repo. Skipped for rc 75 (a
# busy-skip, not a real run) so the last real outcome isn't clobbered.
write_status() {
	local repo="$1" rc="$2" ran="$3" tmp="$4" status outcome
	case "$rc" in
	0) status="ok" ;;
	*) status="failed (exit $rc)" ;;
	esac
	outcome=$(grep -aE '^Done:|no ready tasks|drain stalled|agent failed|board read failed|conflicts with' "$tmp" 2>/dev/null | tail -1)
	mkdir -p "$STATUS_DIR"
	{
		printf 'time=%s\n' "$(date -Is)"
		printf 'ran=%s\n' "$ran"
		printf 'status=%s\n' "$status"
		printf 'outcome=%s\n' "$outcome"
	} >"$STATUS_DIR/$repo"
}

# Run dispatch, streaming its output to the journal while capturing it, then record
# the outcome (unless it was a busy-skip). Returns dispatch's own exit code.
run_repo() {
	local repo="$1"
	shift
	local tmp
	tmp=$(mktemp)
	"$DISPATCH" "$repo" "$@" 2>&1 | tee "$tmp"
	local rc=${PIPESTATUS[0]}
	[ "$rc" -ne 75 ] && write_status "$repo" "$rc" "$*" "$tmp"
	rm -f "$tmp"
	return "$rc"
}

log "starting; interval=${INTERVAL}s config=$CONFIG_DIR"
while true; do
	if [ -f "$CONFIG_DIR/PAUSED" ]; then
		log "paused (remove $CONFIG_DIR/PAUSED to resume)"
		sleep "$INTERVAL"
		continue
	fi

	shopt -s nullglob
	for conf in "$CONFIG_DIR"/repos/*.conf; do
		repo="$(basename "$conf" .conf)"
		[ -f "$CONFIG_DIR/repos/$repo.paused" ] && continue

		# A queued one-off (enqueue <repo> ...) takes precedence over the periodic
		# drain, so a scheduled run (e.g. a steward pass) is picked up at the next
		# free slot without pausing or timing anything. Oldest first (FIFO); one job
		# per repo per tick — the drain resumes next tick.
		job=""
		for f in "$CONFIG_DIR/queue/$repo"/*; do
			job="$f"
			break
		done
		if [ -n "$job" ]; then
			mapfile -t jobargs <"$job"
			run_repo "$repo" "${jobargs[@]}"
			rc=$?
			# 75 = repo busy (a manual dispatch holds the lock): keep the job, retry
			# next tick. Otherwise it ran (success or a now-loud failure) — a one-off
			# runs once, so drop it.
			if [ "$rc" -ne 75 ]; then
				rm -f "$job"
				[ "$rc" -ne 0 ] && log "queued ${jobargs[*]} for $repo exited $rc"
			fi
			continue
		fi

		run_repo "$repo" --drain
		rc=$?
		case "$rc" in
		0) ;;  # ran a drain, or early-exited because nothing was ready
		75) ;; # a run for this repo is already active (flock) — skip
		*) log "dispatch $repo exited $rc" ;;
		esac
	done

	sleep "$INTERVAL"
done
