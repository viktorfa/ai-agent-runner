#!/usr/bin/env bash
# Watcher — run as VIKTOR (typically via a systemd --user unit). Drains repo boards
# through `dispatch` so you just push tickets and walk away; no SSH, no manual dispatch.
#
#   watch            all repos in the registry, sequentially (legacy / single-box mode)
#   watch <repo>     only <repo> — run one process per repo (the `agent-watch@<repo>`
#                    template unit) for parallelism ACROSS repos, while dispatch's
#                    per-repo flock keeps each repo strictly sequential with itself.
#
# Each tick a repo runs its oldest queued one-off (`enqueue <repo> …`) ahead of a
# `--drain`; the flock means runs never overlap within a repo (a busy repo 75-skips).
#
# Per-run status: each real run records `$CONFIG_DIR/status/<repo>` (time, what ran,
# ok/failed, the outcome line) — visible without opening a transcript; the TUI reads it.
#
# Pause: `touch $CONFIG_DIR/PAUSED` (all repos) or `$CONFIG_DIR/repos/<name>.paused`
# (one repo). Stop: `systemctl --user stop agent-watch@<repo>` (or legacy `agent-watch`).
set -uo pipefail

CONFIG_DIR="${AGENT_RUNNER_CONFIG:-$HOME/.config/agent-runner}"
INTERVAL="${WATCH_INTERVAL:-120}"
DISPATCH="$(cd "$(dirname "$0")" && pwd)/dispatch"
REPO_ARG="${1:-}" # empty = serve all registry repos; set = serve only that repo
shopt -s nullglob

log() { printf '[watch %s] %s\n' "$(date -Is)" "$*"; }

STATUS_DIR="$CONFIG_DIR/status"

# Record a run's outcome so it's visible without opening a transcript (and so the TUI
# can read it without sudo). One small key=value file per repo. Skipped for rc 75 (a
# busy-skip, not a real run) so the last real outcome isn't clobbered.
write_status() {
	local repo="$1" rc="$2" ran="$3" tmp="$4" status outcome
	case "$rc" in
	0) status="ok" ;;
	*) status="failed (exit $rc)" ;;
	esac
	outcome=$(grep -aE '^Done:|no ready tasks|drain stalled|agent failed|board read failed|conflicts with' "$tmp" 2>/dev/null | tail -1)
	mkdir -p "$STATUS_DIR"
	{
		printf 'time=%s\n' "$(date -Is)"
		printf 'ran=%s\n' "$ran"
		printf 'status=%s\n' "$status"
		printf 'outcome=%s\n' "$outcome"
	} >"$STATUS_DIR/$repo"
}

# Run dispatch, streaming its output to the journal while capturing it, then record
# the outcome (unless it was a busy-skip). Returns dispatch's own exit code.
run_repo() {
	local repo="$1"
	shift
	local tmp
	tmp=$(mktemp)
	"$DISPATCH" "$repo" "$@" 2>&1 | tee "$tmp"
	local rc=${PIPESTATUS[0]}
	[ "$rc" -ne 75 ] && write_status "$repo" "$rc" "$*" "$tmp"
	rm -f "$tmp"
	return "$rc"
}

# One tick for a single repo: run its oldest queued one-off (ahead of the drain) if
# there is one, else a --drain. dispatch's flock keeps this sequential with itself.
tick_repo() {
	local repo="$1"
	[ -f "$CONFIG_DIR/repos/$repo.conf" ] || {
		log "no registry entry for $repo"
		return
	}
	[ -f "$CONFIG_DIR/repos/$repo.paused" ] && return

	local job="" f rc
	for f in "$CONFIG_DIR/queue/$repo"/*; do
		job="$f"
		break
	done
	if [ -n "$job" ]; then
		local jobargs
		mapfile -t jobargs <"$job"
		run_repo "$repo" "${jobargs[@]}"
		rc=$?
		# 75 = repo busy (a manual dispatch holds the lock): keep the job, retry next
		# tick. Otherwise it ran (ok or a now-loud failure) — a one-off runs once.
		if [ "$rc" -ne 75 ]; then
			rm -f "$job"
			[ "$rc" -ne 0 ] && log "queued ${jobargs[*]} for $repo exited $rc"
		fi
		return
	fi

	run_repo "$repo" --drain
	rc=$?
	case "$rc" in
	0 | 75) ;; # ran / early-exited, or busy (flock) — both fine
	*) log "dispatch $repo exited $rc" ;;
	esac
}

log "starting; interval=${INTERVAL}s config=$CONFIG_DIR${REPO_ARG:+ repo=$REPO_ARG}"
while true; do
	if [ -f "$CONFIG_DIR/PAUSED" ]; then
		log "paused (remove $CONFIG_DIR/PAUSED to resume)"
		sleep "$INTERVAL"
		continue
	fi

	if [ -n "$REPO_ARG" ]; then
		tick_repo "$REPO_ARG" # one repo — the template-unit (parallel) mode
	else
		for conf in "$CONFIG_DIR"/repos/*.conf; do
			tick_repo "$(basename "$conf" .conf)" # all repos — legacy single-loop mode
		done
	fi

	sleep "$INTERVAL"
done
