#!/usr/bin/env bash
# Entry point for the TypeScript agent runner — runs the CLI via tsx.
#
# Usage:  bin/agent-runner <run|orchestrate> [options]
set -euo pipefail

RUNNER_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Locate tsx. Standalone: in this repo's node_modules. (A parent node_modules is
# also checked in case the runner is vendored inside a monorepo that hoists deps.)
TSX=""
for cand in \
	"$RUNNER_DIR/node_modules/.bin/tsx" \
	"$RUNNER_DIR/../node_modules/.bin/tsx"; do
	if [ -x "$cand" ]; then
		TSX="$cand"
		break
	fi
done

# Run tsx directly, NOT via `pnpm exec` — pnpm's pre-flight dep check would try to
# `pnpm install` first (hitting npm before the CLI sets the egress proxy). The
# CLI's own setup step installs deps (with the proxy) once it's running.
if [ -z "$TSX" ]; then
	echo "tsx not found under $RUNNER_DIR — run 'pnpm install' once" \
		"(with HTTPS_PROXY=http://127.0.0.1:3128 if locked down)." >&2
	exit 1
fi

exec "$TSX" "$RUNNER_DIR/src/cli.ts" "$@"
